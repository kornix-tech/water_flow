# Generated by soilflow_pflotran.py --mode _test
# Analytical verification test: saturated homogeneous isotropic column.
# Linearized Richards equation -> Darcy equation with constant K = Ks.
# Upper boundary is imposed as constant flux; lower boundary is reference pressure.
# The bottom flux is checked against the analytical steady flux.

SIMULATION
  SIMULATION_TYPE SUBSURFACE
  PROCESS_MODELS
    SUBSURFACE_FLOW flow
      MODE RICHARDS
    /
  /
END

SUBSURFACE

GRID
  TYPE structured
  ORIGIN 0.d0 0.d0 0.d0
  NXYZ 1 1 80
  DXYZ
    1.000000000000d+00
    1.000000000000d+00
    2.500000000000d-02
  /
END

MATERIAL_PROPERTY soil
  ID 1
  POROSITY 4.300000000000d-01
  TORTUOSITY 1.d0
  CHARACTERISTIC_CURVES cc_saturated
  PERMEABILITY
    PERM_X 5.124150679057d-13
    PERM_Y 5.124150679057d-13
    PERM_Z 5.124150679057d-13
  /
/

# Saturation curve is present because RICHARDS mode expects characteristic curves.
# Positive pressure levels keep the domain saturated; the test therefore reduces
# to the linear Darcy column problem.
CHARACTERISTIC_CURVES cc_saturated
  SATURATION_FUNCTION VAN_GENUCHTEN
    LIQUID_RESIDUAL_SATURATION 0.d0
    M 0.5d0
    ALPHA 1.d-4
  /
  PERMEABILITY_FUNCTION MUALEM_VG_LIQ
    LIQUID_RESIDUAL_SATURATION 0.d0
    M 0.5d0
  /
/

OUTPUT
  FORMAT TECPLOT POINT
/

TIME
  FINAL_TIME 1.000000000000d+01 d
  MAXIMUM_TIMESTEP_SIZE 1.000000000000d-01 d
/

REGION all
  COORDINATES
    0.d0 0.d0 0.d0
    1.000000000000d+00 1.000000000000d+00 2.000000000000d+00
  /
END

REGION top
  COORDINATES
    0.d0 0.d0 2.000000000000d+00
    1.000000000000d+00 1.000000000000d+00 2.000000000000d+00
  /
  FACE TOP
END

REGION bottom
  COORDINATES
    0.d0 0.d0 0.d0
    1.000000000000d+00 1.000000000000d+00 0.d0
  /
  FACE BOTTOM
END

FLOW_CONDITION initial
  TYPE
    LIQUID_PRESSURE HYDROSTATIC
  /
  LIQUID_PRESSURE 1.013250000000d+05
END

FLOW_CONDITION bottom_pressure
  TYPE
    LIQUID_PRESSURE DIRICHLET
  /
  LIQUID_PRESSURE 1.013250000000d+05
END

FLOW_CONDITION top_flux
  TYPE
    LIQUID_FLUX NEUMANN
  /
  # PFLOTRAN sign convention: positive boundary flux is inward.
  # imposed_flux_z_m_s is a +z Darcy flux; downward top infiltration has q_z < 0.
  LIQUID_FLUX 1.000000000000d-06
END

INITIAL_CONDITION
  FLOW_CONDITION initial
  REGION all
END

BOUNDARY_CONDITION
  FLOW_CONDITION bottom_pressure
  REGION bottom
END

BOUNDARY_CONDITION
  FLOW_CONDITION top_flux
  REGION top
END

STRATA
  REGION all
  MATERIAL soil
END

END_SUBSURFACE
